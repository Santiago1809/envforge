# Environment
APP_ENV=development
APP_PORT=3000
DEBUG=true

# Database
DATABASE_URL=postgres://user:password@localhost:5432/mydb

# Authentication
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=3600

# APIs
STRIPE_KEY=sk_test_xxxxx
OPENAI_API_KEY=sk-xxxxx
SENDGRID_API_KEY=SG.xxxxx

# AWS
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxx
